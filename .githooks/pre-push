#!/usr/bin/env sh
# Bump patch version, build release zip, sync checksum, commit, and push tag before each branch push.

if [ "$SKIP_VERSION_BUMP" = "1" ]; then
  exit 0
fi

pushed_tags=0
pushed_branches=0

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/tags/*) pushed_tags=1 ;;
    refs/heads/*) pushed_branches=1 ;;
  esac
done

if [ "$pushed_tags" = "1" ] && [ "$pushed_branches" = "0" ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File scripts/bump-version.ps1 patch
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -File scripts/bump-version.ps1 patch
else
  sh scripts/bump-version.sh patch
fi

# build.ps1/build.sh: restore, compile Release DLL, create zip with meta.json, sync manifest checksum
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File build.ps1
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -File build.ps1
else
  sh build.sh
fi

git add VERSION.txt Jellyfin.Plugin.AIRecommendations.csproj manifest.json

if git diff --cached --quiet; then
  exit 0
fi

NEW_VERSION="$(tr -d ' \r\n' < VERSION.txt)"
git commit -m "chore: bump version to ${NEW_VERSION}"

# Push the release tag so GitHub Actions creates the actual GitHub Release and ZIP
git tag "v${NEW_VERSION}"
git push origin "v${NEW_VERSION}"

exit 0
