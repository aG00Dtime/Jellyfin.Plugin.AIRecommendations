#!/usr/bin/env sh
# Bump patch version, build, sync checksum, and commit before each push.

if [ "$SKIP_VERSION_BUMP" = "1" ]; then
  exit 0
fi

pushed_tags=0
pushed_branches=0

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/tags/*) pushed_tags=1 ;;
    refs/heads/*) pushed_branches=1 ;;
  esac
done

if [ "$pushed_tags" = "1" ] && [ "$pushed_branches" = "0" ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File scripts/bump-version.ps1 patch
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -File scripts/bump-version.ps1 patch
else
  sh scripts/bump-version.sh patch
fi

if command -v dotnet >/dev/null 2>&1; then
  dotnet build -c Release
  if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -File scripts/sync-manifest-checksum.ps1
  elif command -v powershell >/dev/null 2>&1; then
    powershell -NoProfile -File scripts/sync-manifest-checksum.ps1
  else
    sh scripts/sync-manifest-checksum.sh
  fi
else
  echo "pre-push: dotnet not found — commit blocked until checksum is synced via build.ps1" >&2
  exit 1
fi

git add VERSION.txt Jellyfin.Plugin.AIRecommendations.csproj manifest.json

if git diff --cached --quiet; then
  exit 0
fi

NEW_VERSION="$(tr -d ' \r\n' < VERSION.txt)"
git commit -m "chore: bump version to ${NEW_VERSION}"

exit 0
