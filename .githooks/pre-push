#!/usr/bin/env sh
# Bump patch version, commit, and push release tag before each branch push.
# CI (GitHub Actions) handles the actual build, zip, checksum, and release creation.

if [ "$SKIP_VERSION_BUMP" = "1" ]; then
  exit 0
fi

pushed_tags=0
pushed_branches=0

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/tags/*) pushed_tags=1 ;;
    refs/heads/*) pushed_branches=1 ;;
  esac
done

if [ "$pushed_tags" = "1" ] && [ "$pushed_branches" = "0" ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File scripts/bump-version.ps1 patch
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -File scripts/bump-version.ps1 patch
else
  sh scripts/bump-version.sh patch
fi

git add VERSION.txt Jellyfin.Plugin.AIRecommendations.csproj manifest.json

if git diff --cached --quiet; then
  exit 0
fi

NEW_VERSION="$(tr -d ' \r\n' < VERSION.txt)"
git commit -m "chore: bump version to ${NEW_VERSION}"

# Push the release tag — this triggers GitHub Actions to build the zip,
# create the GitHub Release, and update the manifest checksum.
git tag "v${NEW_VERSION}"
git push origin "v${NEW_VERSION}"

exit 0
